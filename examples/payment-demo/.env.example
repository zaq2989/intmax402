# intmax402 payment-demo environment variables

# Server private key (Ethereum private key for INTMAX L2 wallet)
# This key is used by the server to receive payments on INTMAX
SERVER_PRIVATE_KEY=0xYOUR_SERVER_PRIVATE_KEY_HERE

# Client private key (for demo client script only - DO NOT use real funds in demo)
CLIENT_PRIVATE_KEY=0xYOUR_CLIENT_PRIVATE_KEY_HERE

# INTMAX environment: "testnet" or "mainnet"
INTMAX_ENV=testnet

# L1 RPC URL (Ethereum node)
# Testnet (Sepolia): https://sepolia.gateway.tenderly.co
# Mainnet: https://mainnet.infura.io/v3/YOUR_KEY
L1_RPC_URL=https://sepolia.gateway.tenderly.co

# Server URL for demo client
SERVER_URL=http://localhost:3761

# Port for demo server
PORT=3761

# INTMAX402 nonce secret (used for HMAC-based nonce generation)
INTMAX402_SECRET=change-me-in-production
